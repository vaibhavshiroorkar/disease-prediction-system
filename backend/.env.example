# ── Backend Environment Variables ─────────────────────────────────────────────
# Copy to .env and fill in your values.
# On Render, set these in the Environment tab of your service.

# ML model directory (already set correctly by the Dockerfile / render.yaml)
ML_MODELS_DIR=/ml/models

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://diseasepredictionsystem.vercel.app

# Weather API key (optional — leave blank to disable live weather data)
WEATHER_API_KEY=

# Supabase (optional — enables prediction logging)
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-public-key>
